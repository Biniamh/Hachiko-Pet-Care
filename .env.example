# ─────────────────────────────────────────────────────────────────────────────
# Hachiko Veterinary Care — Local Development Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# You can use a local PostgreSQL instance or a free cloud DB (e.g. Neon, Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/hachiko_vet

# Session secret — any long random string works for development
SESSION_SECRET=change-me-to-a-long-random-secret

# Admin portal credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password-here

# Resend API key for sending confirmation emails
# Get one free at https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

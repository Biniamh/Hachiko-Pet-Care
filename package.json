{
  "name": "hachiko-vet",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "artifacts/hachiko",
    "artifacts/api-server",
    "lib/api-client-react",
    "lib/api-zod",
    "lib/db",
    "lib/api-spec"
  ],
  "scripts": {
    "dev": "concurrently --names \"api,web\" --prefix-colors \"green,blue\" \"npm run dev --workspace=artifacts/api-server\" \"npm run dev:local --workspace=artifacts/hachiko\"",
    "dev:api": "npm run dev --workspace=artifacts/api-server",
    "dev:web": "npm run dev:local --workspace=artifacts/hachiko",
    "build": "npm run typecheck && npm run build --workspaces --if-present",
    "typecheck": "tsc --build && npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
